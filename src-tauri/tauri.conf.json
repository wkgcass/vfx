{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "vfx-app",
  "version": "1.4.0",
  "identifier": "io.vproxy.vfx.app",
  "build": {
    "frontendDist": "../dist",
    "beforeBuildCommand": "pnpm build"
  },
  "app": {
    "windows": [
      {
        "label": "main",
        "title": "VFX",
        "width": 1280,
        "height": 800,
        "minWidth": 256,
        "minHeight": 128,
        "decorations": false,
        "transparent": true,
        "resizable": false,
        "fullscreen": false,
        "center": true,
        "shadow": true,
        "url": "index.html",
        "visible": false
      }
    ],
    "security": {
      "csp": "default-src 'self'; img-src 'self' data: blob: asset: https://asset.localhost; font-src 'self' data: blob: asset: https://asset.localhost; style-src 'self' 'unsafe-inline'; script-src 'self'"
    }
  },
  "bundle": {
    "active": true,
    "targets": "all",
    "icon": [
      "icons/32x32.png",
      "icons/128x128.png",
      "icons/128x128@2x.png",
      "icons/icon.icns",
      "icons/icon.ico"
    ]
  }
}
