{
  "name": "vfx-ts",
  "version": "1.4.0",
  "description": "TypeScript + Tauri port of the vfx JavaFX UI library",
  "type": "module",
  "private": true,
  "scripts": {
    "typecheck": "tsc --noEmit -p src-ts/tsconfig.json",
    "build": "vite build && node scripts/copy-resources.mjs",
    "clean": "node -e \"require('fs').rmSync('dist',{recursive:true,force:true})\"",
    "tauri": "tauri",
    "tauri:dev": "pnpm build && tauri dev",
    "tauri:build": "tauri build"
  },
  "dependencies": {
    "@tauri-apps/api": "^2.4.0",
    "@tauri-apps/plugin-os": "^2.2.0"
  },
  "devDependencies": {
    "@tauri-apps/cli": "^2.4.0",
    "typescript": "^5.7.0",
    "vite": "^8.0.16"
  },
  "packageManager": "pnpm@11.0.9"
}
